# =============================
# MAXXI — Agente IA SaaS
# =============================

# ── BANCO DE DADOS (obrigatório) ──
DATABASE_URL=postgres://postgres:SENHA@HOST:5432/postgres

# ── Autenticação ──
# OBRIGATÓRIO em produção. Usado como segredo do JWT.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GERE_UM_SECRET_SEGURO_AQUI

# Admin legado (compatibilidade CITmax — opcional no SaaS)
# Se não definido, só tokens JWT são aceitos.
ADMIN_PASSWORD=

# ── Servidor ──
PORT=3000

# ── Configs por tenant ──
# No SaaS, cada tenant configura suas integrações pelo painel (tenant_configs).
# As variáveis abaixo são usadas apenas como FALLBACK para o tenant CITmax (legado).

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-COLE_SUA_CHAVE_AQUI

# Chatwoot
CHATWOOT_URL=https://chatwoot.citmax.com.br
CHATWOOT_API_TOKEN=COLE_SEU_TOKEN_AQUI
CHATWOOT_HUMAN_TEAM_ID=1
CHATWOOT_ACCOUNT_ID=1

# ElevenLabs (opcional)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# OpenAI Whisper (opcional)
OPENAI_API_KEY=sk-proj-COLE_SUA_CHAVE_OPENAI_AQUI

# Gateway SMS
SMS_GATEWAY_TOKEN=
SMS_GATEWAY_TEMPLATE=

# TR-069 / ACS Server
ACS_PORT=7547
ACS_USER=maxxi
ACS_PASS=SENHA_ACS_SEGURA
TR069_SGP_USER=
TR069_SGP_PASS=

# ── CORS ──
# Defina para restringir origens em produção
CORS_ORIGIN=
