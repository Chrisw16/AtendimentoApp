# ── Claude / Anthropic ──
ANTHROPIC_API_KEY=sk-ant-COLE_SUA_CHAVE_AQUI

# ── Chatwoot ──
CHATWOOT_URL=https://chatwoot.citmax.com.br
CHATWOOT_API_TOKEN=COLE_SEU_TOKEN_AQUI
CHATWOOT_HUMAN_TEAM_ID=1
CHATWOOT_ACCOUNT_ID=1

# ── Servidor ──
PORT=3000
ADMIN_PASSWORD=citmax2026
OUTBOUND_SECRET=citmax2026

# ── ElevenLabs (opcional) ──
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── OpenAI Whisper (opcional) ──
OPENAI_API_KEY=sk-proj-COLE_SUA_CHAVE_OPENAI_AQUI

# ── Gateway SMS (SGP → WhatsApp) ──
# Token configurado no SGP em: Sistema → SMS Gateway → Config → token
SMS_GATEWAY_TOKEN=2XPlm5yUV#&r
# Template aprovado pela Meta para envios fora da janela de 24h (opcional)
# Se não configurado, só envia para clientes que já conversaram nas últimas 24h
SMS_GATEWAY_TEMPLATE=

# ── TR-069 / ACS Server ──
# Porta do servidor ACS (padrão TR-069: 7547)
ACS_PORT=7547
# Credenciais Basic Auth que as ONUs usam para conectar no ACS
# Configure o mesmo user/pass nas ONUs (ACS URL: http://SEU_IP:7547/)
ACS_USER=citmax
ACS_PASS=SENHA_ACS_SEGURA

# ── TR-069 / Gerenciador CPE (SGP) ──
# Credenciais Basic Auth para o Gerenciador CPE do SGP
# Endpoint base: https://citrn.sgp.net.br/api/cpemanager/servico/{id_servico}/*
TR069_SGP_USER=USUARIO_CPE_SGP
TR069_SGP_PASS=SENHA_CPE_SGP
